# "production" na produkciji (uključuje HSTS i CORS deny-by-default
# fallback). Prazno/bilo šta drugo = dev (dozvoljava CORS allow-all kad je
# CORS_ALLOWED_ORIGINS prazan).
NODE_ENV=
HOST=
PORT=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=
JWT_SECRET=
AGENT_ENROLL_TOKEN=
AGENT_SIGNING_CERT_PATH=
AGENT_SIGNING_KEY_PATH=
SSL_CERT=
SSL_KEY=
# Origin-i sa kojih browser sme da zove ovaj API. Browser šalje Origin
# header i na same-origin fetch/XHR pozive (naročito POST/PUT/DELETE), a
# ova provera to ne razlikuje od cross-origin - MORA da sadrži i sopstveni
# origin backend-a kad on sam servira frontend (npr.
# https://10.230.62.81:3000), ne sme da ostane prazno. U dev modu, prazno
# = dozvoli sve (pogodnost, ne oslanjati se na to u produkciji).
CORS_ALLOWED_ORIGINS=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
