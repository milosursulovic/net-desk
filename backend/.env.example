# "production" na produkciji (uključuje HSTS i CORS deny-by-default
# fallback). Prazno/bilo šta drugo = dev (dozvoljava CORS allow-all kad je
# CORS_ALLOWED_ORIGINS prazan).
NODE_ENV=
HOST=
PORT=
DB_HOST=
DB_PORT=
DB_USER=
DB_PASS=
DB_NAME=
JWT_SECRET=
AGENT_ENROLL_TOKEN=
AGENT_SIGNING_CERT_PATH=
AGENT_SIGNING_KEY_PATH=
SSL_CERT=
SSL_KEY=
# Cross-origin browser pristup (npr. lokalni dev gde frontend radi na
# drugom portu). Prazno u produkciji ako backend sam servira frontend
# (isti origin) - vidi VITE_API_URL u frontend/.env.example.
CORS_ALLOWED_ORIGINS=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
